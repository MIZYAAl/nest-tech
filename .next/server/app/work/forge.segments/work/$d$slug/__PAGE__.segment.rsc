}]],["$","h2",null,{"children":"Current Status"}],["$","p",null,{"children":"Forge is in active development. The core HAL and runtime are feature-complete. We're currently working on the cloud management console and hardening the OTA update system."}]]}],["$","div",null,{"className":"case-sidebar","children":[["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Status"}],["$","p",null,{"children":"Development"}]]}],["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Stack"}],["$","div",null,{"className":"sidebar-tags","children":[["$","span","Hardware Interface",{"className":"tag","children":"Hardware Interface"}],["$","span","C++",{"className":"tag","children":"C++"}],["$","span","Embedded",{"className":"tag","children":"Embedded"}],["$","span","IoT",{"className":"tag","children":"IoT"}]]}]]}],["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Category"}],["$","p",null,{"children":"Hardware Interface / IoT"}]]}]]}]]}]]}],null,["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"pyGCzhn3iTGD2__OF9WVo"}
