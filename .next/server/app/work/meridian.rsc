7:["$","div",null,{"className":"page-wrap","children":[["$","$L6",null,{"className":"page-back","href":"/#work","children":[["$","svg",null,{"width":"16","height":"16","viewBox":"0 0 16 16","fill":"none","children":["$","path",null,{"d":"M10 3L5 8L10 13","stroke":"currentColor","strokeWidth":"1.5","strokeLinecap":"round"}]}],"Back"]}],["$","div",null,{"className":"case-hero","children":[["$","div",null,{"className":"case-meta","style":{"marginBottom":20},"children":[["$","span",null,{"className":"tag","children":"Infrastructure"}],["$","span",null,{"className":"status-badge status-production","children":"Production"}]]}],["$","h1",null,{"children":"Meridian"}],["$","div",null,{"className":"case-meta","children":[["$","span","Rust",{"className":"tag","children":"Rust"}],["$","span","Go",{"className":"tag","children":"Go"}],["$","span","Kubernetes",{"className":"tag","children":"Kubernetes"}]]}]]}],["$","div",null,{"className":"case-body","children":[["$","div",null,{"className":"case-content","children":[["$","p",null,{"children":"A distributed systems platform for real-time data processing at scale. Built to handle millions of events per second with sub-millisecond latency."}],["$","h2",null,{"children":"The Problem"}],["$","p",null,{"children":"Existing streaming infrastructure required teams to manage complex clusters, tune countless parameters, and accept unpredictable tail latencies. As data volumes grew, operational overhead grew proportionally. We set out to build a platform that made high-throughput, low-latency data processing accessible — without the operational burden."}],["$","h2",null,{"children":"Architecture"}],[["$","p","0",{"children":"Meridian is built in Rust for its core processing pipeline, delivering deterministic performance and memory safety without a garbage collector. The control plane is implemented in Go for its excellent concurrency primitives and operational tooling ecosystem."}],["$","p","1",{"children":"The system is deployed on Kubernetes and uses a custom scheduling layer to co-locate related processing units, reducing inter-node communication and improving cache locality."}]],["$","h2",null,{"children":"Outcomes"}],["$","p",null,{"children":"In production, Meridian processes over 50 million events per second with p99 latency under 2ms. The system has maintained 99.99% uptime over 18 months of operation."}]]}],["$","div",null,{"className":"case-sidebar","children":[["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Status"}],["$","p",null,{"children":"Production"}]]}],["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Stack"}],["$","div",null,{"className":"sidebar-tags","children":[["$","span","Infrastructure",{"className":"tag","children":"Infrastructure"}],["$","span","Rust",{"className":"tag","children":"Rust"}],["$","span","Go",{"className":"tag","children":"Go"}],["$","span","Kubernetes",{"className":"tag","children":"Kubernetes"}]]}]]}],["$","div",null,{"className":"sidebar-block","children":[["$","h4",null,{"children":"Category"}],["$","p",null,{"children":"Infrastructure / Data Systems"}]]}]]}]]}]]}]
